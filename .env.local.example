# Supabase
# 値は Supabase ダッシュボード Settings → API Keys で確認する。
# Production / Preview / Development で同じSupabaseプロジェクトを使う場合は同じ値でよい。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# LINE Login を Supabase Custom OAuth2 で登録した provider ID。
# 未設定なら custom:line を使う。
NEXT_PUBLIC_SUPABASE_LINE_PROVIDER=custom:line

# Supabase（サーバー専用）
# Webhook から profiles.plan を更新するために使う。チャットには貼らない。
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
# ローカル・Preview はテストモード、本番は本番モードの値を使う。
STRIPE_SECRET_KEY=

# ローカルは Stripe CLI の whsec_... を使う。
# Vercel は Stripe Dashboard の Webhook endpoint ごとに発行される別の whsec_... を使う。
STRIPE_WEBHOOK_SECRET=

# テストモードと本番モードでは Price ID が別になる。
# 下の値は現在の買い切りCheckout用。サブスクリプション移行後に削除する。
NEXT_PUBLIC_STRIPE_PRICE_LOW_3M_PASS=price_1TaoHeFUkpvTvQkQVLaX7zOn
NEXT_PUBLIC_STRIPE_PRICE_LOW_YEAR_PASS=price_1TaoHiFUkpvTvQkQ3uHmAiW6
NEXT_PUBLIC_STRIPE_PRICE_EXAM_YEAR_PASS=price_1TUwmrFUkpvTvQkQy8InMoBp

# 14日無料トライアル後の自動課金に使う recurring Price ID。
# Stripe Dashboard で作成後、Development / Preview / Production に設定する。
STRIPE_PRICE_LOW_3M_SUBSCRIPTION=
STRIPE_PRICE_LOW_YEAR_SUBSCRIPTION=
STRIPE_PRICE_EXAM_YEAR_SUBSCRIPTION=

# Customer Portal の設定ID。キャンセル・支払い方法変更・請求履歴を提供する。
STRIPE_BILLING_PORTAL_CONFIGURATION_ID=

# Checkout の戻り先URL。
# ローカルは http://localhost:3000
# Vercel Production は本番公開URL
# Vercel Preview は未設定でも VERCEL_URL から自動推定される。
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend（問い合わせフォームのメール送信）
# https://resend.com で取得した API キー。
# Production / Preview に設定すれば、/contact フォームから info@ortace.jp に届く。
RESEND_API_KEY=

# 任意。未設定なら noreply@ortace.jp（送信元）／ info@ortace.jp（送信先）が既定値。
CONTACT_FROM_EMAIL=noreply@ortace.jp
CONTACT_TO_EMAIL=info@ortace.jp

# 管理画面（/admin）は Basic 認証と Supabase Auth user id の両方が必要。
# Basic 認証は推測されにくい ASCII のユーザー名・長いランダムパスワードを設定する。
ADMIN_BASIC_AUTH_USER=
ADMIN_BASIC_AUTH_PASSWORD=
# 管理画面に入れる Supabase Auth user id。複数はカンマ区切り。
ADMIN_USER_IDS=

# 合格サポート保証の申請期限（JST, YYYY-MM-DD）。合格発表後に設定する。未設定なら受付開始前として扱う。
SUPPORT_CLAIM_DEADLINE=

# Cloudflare Turnstile（問い合わせフォームのスパム対策）
# 未設定なら Turnstile チャレンジは省略される（フォームは動作する）。
# 設定する場合はサイトキー（公開）とシークレット（サーバー）を両方必要。
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Google Analytics 4 測定ID（G-XXXXXXXXXX 形式）
# 未設定なら GA タグは出力されない（Vercel Analytics / Speed Insights は常に有効）。
NEXT_PUBLIC_GA_ID=

# Sentry エラートラッキング
# 未設定なら何もしない（コード上は安全）。本番運用前に投入推奨。
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# 以下はソースマップを Sentry にアップロードする場合のみ必要
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
# 任意。Sentry導入確認用の一時トークン。設定した場合のみ /api/debug/sentry-test?token=... が500を発生させる。
SENTRY_TEST_TOKEN=
