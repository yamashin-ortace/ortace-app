# Supabase
# 値は Supabase ダッシュボード Settings → API Keys で確認する。
# Production / Preview / Development で同じSupabaseプロジェクトを使う場合は同じ値でよい。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase（サーバー専用）
# Webhook から profiles.plan を更新するために使う。チャットには貼らない。
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
# ローカル・Preview はテストモード、本番は本番モードの値を使う。
STRIPE_SECRET_KEY=

# ローカルは Stripe CLI の whsec_... を使う。
# Vercel は Stripe Dashboard の Webhook endpoint ごとに発行される別の whsec_... を使う。
STRIPE_WEBHOOK_SECRET=

# テストモードと本番モードでは Price ID が別になる。
# 下の値は現在のサンドボックス用。
NEXT_PUBLIC_STRIPE_PRICE_LOW_YEAR_PASS=price_1TUwkLFUkpvTvQkQyHTN8ha5
NEXT_PUBLIC_STRIPE_PRICE_EXAM_YEAR_PASS=price_1TUwmrFUkpvTvQkQy8InMoBp

# Checkout の戻り先URL。
# ローカルは http://localhost:3000
# Vercel Production は本番公開URL
# Vercel Preview は未設定でも VERCEL_URL から自動推定される。
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend（問い合わせフォームのメール送信）
# https://resend.com で取得した API キー。
# Production / Preview に設定すれば、/contact フォームから info@ortace.jp に届く。
RESEND_API_KEY=

# 任意。未設定なら noreply@ortace.jp（送信元）／ info@ortace.jp（送信先）が既定値。
CONTACT_FROM_EMAIL=noreply@ortace.jp
CONTACT_TO_EMAIL=info@ortace.jp

# Cloudflare Turnstile（問い合わせフォームのスパム対策）
# 未設定なら Turnstile チャレンジは省略される（フォームは動作する）。
# 設定する場合はサイトキー（公開）とシークレット（サーバー）を両方必要。
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Google Analytics 4 測定ID（G-XXXXXXXXXX 形式）
# 未設定なら GA タグは出力されない（Vercel Analytics / Speed Insights は常に有効）。
NEXT_PUBLIC_GA_ID=
